# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_STATIC_ROOT=staticfiles
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false

# YOLO
YOLO_MODEL=models/yolo26x.pt
YOLO_DEVICE=0
YOLO_IMAGE_SIZE=640
YOLO_CONFIDENCE=0.50
YOLO_FRAME_STRIDE=1
YOLO_QUANTIZE=16
YOLO_COUNT_WINDOW=10
YOLO_STATE_STALE_SECONDS=15

# Optional override. Normally run-yolo reads a Video Feed from the database.
# YOLO_SOURCE=rtsp://username:password@camera.example/live
